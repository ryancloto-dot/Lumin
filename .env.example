LUMIN_REQUEST_TIMEOUT=60
LUMIN_CACHE_SIMILARITY_THRESHOLD=0.58
LUMIN_MAX_CACHE_ENTRIES=512
LUMIN_COMPRESSION_TIER=free
LUMIN_VERIFY_COMPRESSED=true
LUMIN_VERIFIER_MODEL=gpt-5.4-nano
LUMIN_SEMANTIC_SIMILARITY_HIGH=0.85
LUMIN_SEMANTIC_SIMILARITY_LOW=0.30
LUMIN_SEMANTIC_DENSITY_THRESHOLD=0.32
LUMIN_SEMANTIC_SUMMARY_TRIGGER_TURNS=10
LUMIN_CHUNK_RELEVANCE_THRESHOLD=0.18
LUMIN_CHUNK_MAX_CHUNKS=6
LUMIN_TRANSPILE_MIN_SAVED_TOKENS=5
LUMIN_TRANSPILE_MIN_SAVED_PCT=8
LUMIN_DAILY_BUDGET=10.00
LUMIN_MONTHLY_BUDGET=100.00
LUMIN_ALERT_THRESHOLD=0.80
LUMIN_DASHBOARD_KEY=lumin_dev_key_change_me
LUMIN_DESKTOP_SECRET=lumin_desktop_secret_change_me
