LUMIN_NANOCLAW_ROOT=/home/ryan/Lumin/nanoclaw
LUMIN_NANOCLAW_CLI_TIMEOUT=90
LUMIN_NANOCLAW_PROXY_URL=http://host.docker.internal:8000
LUMIN_CHAT_FALLBACK_MODEL=gpt-5.4-mini
LUMIN_DESKTOP_TASK_WAIT_SECONDS=60
LUMIN_DESKTOP_AGENT_POLL_SECONDS=3
LUMIN_CONTEXT_DISTILL_MAX_SESSIONS=256
LUMIN_CONTEXT_DISTILL_MAX_BLOCKS_PER_SESSION=128
LUMIN_CONTEXT_DISTILL_MIN_SAVED_TOKENS=8
LUMIN_CONTEXT_DISTILL_MIN_SAVED_PCT=3
LUMIN_TOON_ENABLED=true
LUMIN_TOON_MIN_SAVINGS=10
LUMIN_TOON_MIN_ARRAY_SIZE=3
LUMIN_ENABLE_EXPERIMENTS=true
LUMIN_ALLOWED_EXPERIMENTS=cget_v0,scaffold_fill_v0,spe_v0
